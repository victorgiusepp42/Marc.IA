# Marc.IA — exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o .env real (já está no .gitignore).

# === Anthropic API ===
# Chave primária (compartilhada do time Marc.IA)
ANTHROPIC_API_KEY=
# URL custom da chave primária (ex: proxy interno). Opcional.
ANTHROPIC_BASE_URL=
# Chave fallback (de outro integrante). Opcional.
ANTHROPIC_API_KEY_FALLBACK=

# === Banco de dados ===
# SQLite local (dev) — caminho relativo à raiz do projeto
DATABASE_URL=sqlite:///data/marcia.db

# === Flask ===
# Usada para assinar os session cookies. Gere com:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Em produção, gere um valor novo e nunca reutilize o de dev.
FLASK_SECRET_KEY=

# === Google OAuth 2.0 ===
# Obtidos em https://console.cloud.google.com/ → APIs e Serviços → Credenciais
# Veja docs/CRONOGRAMA.md seção AUTH e o plano sequential-coalescing-castle.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Domínio institucional ===
# Login é restrito a alunos UFCAT. Conta com outro email retorna 403.
# Em dev, comente/limpe para testar com contas pessoais (Google permite
# até 100 test users antes da verificação oficial do app).
DOMINIO_ALUNO=@discente.ufcat.edu.br